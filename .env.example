# .env.example — omnimarket
#
# Generated by scripts/generate_env_example.py from the Settings model.
# Do NOT hand-edit. Re-generate after adding or removing Settings fields:
#
#   uv run python scripts/generate_env_example.py
#
# All values are empty / false / 0 by default.
# Enable a service by setting its ENABLE_* flag to true and filling
# in the required fields documented below.

# ======================================================================
# Service enable flags
# ======================================================================

# Enable Kafka producer/consumer wiring. Defaults False for safety.
# ENABLE_KAFKA=false

# Enable embedding/memory service wiring. Defaults False.
# ENABLE_MEMORY_SERVICE=false

# Enable PostgreSQL connections. When True, either a *_DB_URL must be set or
# all individual POSTGRES_* fields must be configured.
# ENABLE_POSTGRES=false

# Enable Qdrant connections. Defaults False for safety.
# ENABLE_QDRANT=false

# Enable Valkey/Redis connections. Defaults False for safety.
# ENABLE_VALKEY=false

# ======================================================================
# Kafka / Redpanda
# ======================================================================

# Kafka broker addresses (comma-separated host:port pairs). REQUIRED when
# ENABLE_KAFKA=true. No default to prevent silent localhost connections.
# KAFKA_BOOTSTRAP_SERVERS=

# Single-broker convenience alias for kafka_bootstrap_servers. When unset,
# Settings reads kafka_bootstrap_servers.
# KAFKA_BROKER=

# Kafka consumer group ID for omnimarket consumers.
# KAFKA_CONSUMER_GROUP=

# Environment label (dev / staging / prod) for logging only. Not used for
# topic prefixing.
# KAFKA_ENVIRONMENT=

# Redpanda admin API host. Used by node_baseline_capture probes. REQUIRED only
# by probes that target Redpanda admin.
# REDPANDA_ADMIN_HOST=

# Redpanda admin API port (typically 9644).
# REDPANDA_ADMIN_PORT=

# ======================================================================
# PostgreSQL
# ======================================================================

# Full PostgreSQL connection URL for the omnibase_infra database. When set,
# takes precedence over individual POSTGRES_* fields. Format:
# postgresql://user:password@host:port/dbname
# OMNIBASE_INFRA_DB_URL=

# Full PostgreSQL connection URL for the omnidash_analytics projection
# database. When set, takes precedence over POSTGRES_* fields.
# OMNIDASH_ANALYTICS_DB_URL=

# PostgreSQL database name for omnimarket. REQUIRED when ENABLE_POSTGRES=true
# and no full DSN is provided.
# POSTGRES_DATABASE=

# PostgreSQL host. REQUIRED when ENABLE_POSTGRES=true and no full DSN is
# provided. No default to prevent silent localhost connections.
# POSTGRES_HOST=

# PostgreSQL password. REQUIRED when ENABLE_POSTGRES=true and no full DSN is
# provided.
# POSTGRES_PASSWORD=

# PostgreSQL port. REQUIRED when ENABLE_POSTGRES=true and no full DSN is
# provided. Standard port is 5432. 0 = unconfigured.
# POSTGRES_PORT=

# PostgreSQL username. REQUIRED when ENABLE_POSTGRES=true and no full DSN is
# provided.
# POSTGRES_USER=

# ======================================================================
# Qdrant (vector DB)
# ======================================================================

# Qdrant host. REQUIRED when ENABLE_QDRANT=true.
# QDRANT_HOST=

# Qdrant port. REQUIRED when ENABLE_QDRANT=true.
# QDRANT_PORT=

# ======================================================================
# Valkey / Redis-compatible cache
# ======================================================================

# Valkey/Redis host. REQUIRED when ENABLE_VALKEY=true.
# VALKEY_HOST=

# Valkey/Redis port. REQUIRED when ENABLE_VALKEY=true.
# VALKEY_PORT=

# ======================================================================
# LLM endpoints
# ======================================================================

# Model identifier for the fast/reasoning endpoint.
# LLM_CODER_FAST_MODEL_ID=

# Base URL for the fast/reasoning LLM endpoint.
# LLM_CODER_FAST_URL=

# Model identifier for the coder endpoint (passed verbatim to the
# OpenAI-compatible API).
# LLM_CODER_MODEL_ID=

# Base URL for the primary coder LLM endpoint. Empty by default; set in env
# when invoking coder-backed features.
# LLM_CODER_URL=

# Model identifier for the embedding endpoint.
# LLM_EMBEDDING_MODEL_ID=

# Base URL for the embedding endpoint.
# LLM_EMBEDDING_URL=

# GLM cloud API key.
# LLM_GLM_API_KEY=

# GLM cloud model identifier.
# LLM_GLM_MODEL_NAME=

# GLM cloud API base URL (e.g. https://api.z.ai).
# LLM_GLM_URL=

# Model identifier for the reasoner endpoint.
# LLM_REASONER_MODEL_ID=

# Base URL for the dedicated reasoner endpoint.
# LLM_REASONER_URL=

# ======================================================================
# Cloud API keys
# ======================================================================

# Anthropic API key. Required only when an Anthropic-backed node is invoked.
# ANTHROPIC_API_KEY=

# Gemini API key (alias for google_api_key in some nodes).
# GEMINI_API_KEY=

# Google API key (Gemini, etc.).
# GOOGLE_API_KEY=

# OpenAI API key. Required only when an OpenAI-backed node is invoked.
# OPENAI_API_KEY=

# ======================================================================
# GitHub / Linear
# ======================================================================

# Alternative GitHub PAT name used by some scripts.
# GH_PAT=

# GitHub Personal Access Token. Required only by skills that call the GitHub
# REST/GraphQL API directly.
# GITHUB_TOKEN=

# Linear API key. Required only by skills/nodes that read or write Linear
# tickets.
# LINEAR_API_KEY=

# ======================================================================
# Memory service / embedding
# ======================================================================

# Embedding model URL used by code-embedding nodes. REQUIRED when
# ENABLE_MEMORY_SERVICE=true.
# EMBEDDING_MODEL_URL=

# ======================================================================
# ONEX runtime / emit daemon / infra targets
# ======================================================================

# Base URL for the omnidash API (used by skills that query projections). Empty
# disables dashboard probes.
# ONEX_DASHBOARD_API=

# Alternative emit-daemon socket path used by some scripts.
# ONEX_EMIT_DAEMON_SOCKET=

# Path to the omniclaude emit daemon Unix socket. Read by hooks that publish
# events. Empty disables daemon emission.
# ONEX_EMIT_SOCKET_PATH=

# Spool directory for buffered events.
# ONEX_EMIT_SPOOL_DIR=

# SSH target for infra hosts (used by deploy/redeploy nodes). No default —
# must be explicitly set.
# ONEX_INFRA_SSH_TARGET=

# Override for ONEX state root. Falls back to ONEX_STATE_DIR raw env when
# unset (bootstrap-only).
# ONEX_STATE_ROOT=

# Pattern-B runtime address (used by codex adapter).
# ONEX_TARGET_RUNTIME_ADDRESS=

# ======================================================================
# Miscellaneous
# ======================================================================

# Slack bot token (used by notification nodes).
# SLACK_BOT_TOKEN=
